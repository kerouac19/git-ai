# Install this file as: /opt/git-ai/.env

PORT=3000
APP_ENV=production

JWT_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_48
GIT_AI_API_KEY=REPLACE_WITH_CLIENT_API_KEY
# GIT_AI_API_KEYS=OPTIONAL_COMMA_SEPARATED_EXTRA_KEYS
ENCRYPTION_MASTER_KEY=REPLACE_WITH_OPENSSL_RAND_HEX_32
CAS_ENCRYPTION_KEY=REPLACE_WITH_OPENSSL_RAND_BASE64_48

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=git_ai
DB_PASSWORD=REPLACE_WITH_DB_PASSWORD
DB_NAME=git_ai
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

CORS_ORIGIN=https://git-ai.example.com
TRUST_PROXY=1
HTTPS_REDIRECT=false
JSON_BODY_LIMIT=2mb

DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001
DEFAULT_USER_EMAIL=admin@example.com
DEFAULT_USER_NAME=Admin
DEFAULT_USER_ROLE=admin
DEFAULT_PERSONAL_ORG_ID=example-org
DEFAULT_ORG_NAME=Example Org
DEFAULT_ORG_SLUG=example-org
