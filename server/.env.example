PORT=3000
NODE_ENV=development

# Server URL / browser behavior
CORS_ORIGIN=http://localhost:3000
TRUST_PROXY=false
HTTPS_REDIRECT=false
DEV_HTTPS=false
# DEV_HTTPS_KEY_PATH=certs/localhost-key.pem
# DEV_HTTPS_CERT_PATH=certs/localhost.pem
JSON_BODY_LIMIT=2mb

# Auth
JWT_SECRET=replace-with-a-long-random-secret
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001
DEFAULT_USER_EMAIL=git-ai@example.local
DEFAULT_USER_NAME="Git AI User"
DEFAULT_USER_ROLE=user
DEFAULT_PERSONAL_ORG_ID=git-ai-local-org
DEFAULT_ORG_NAME="Git AI Local"
DEFAULT_ORG_SLUG=git-ai-local

# Encryption
ENCRYPTION_MASTER_KEY=replace-with-64-char-hex-string
CAS_ENCRYPTION_KEY=replace-with-a-long-random-secret

# Database
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=git_ai
# DATABASE_URL=postgresql://postgres@127.0.0.1:5432/git_ai
# DB_SSL=false
# DB_SSL_REJECT_UNAUTHORIZED=false
