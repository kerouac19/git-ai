generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AuthorshipRecord {
  id                      String   @id @default(uuid()) @db.Uuid
  userId                  String
  gitCommitHash           String
  fileAttributions        String
  createdAt               DateTime @default(now()) @db.Timestamptz
  updatedAt               DateTime @updatedAt @db.Timestamptz
  aiAttributionPercentage Float

  @@map("authorship_records")
}

model CommitAttribution {
  id                    String   @id @default(uuid()) @db.Uuid
  commitHash            String
  author                String
  fileChanges           String
  aiContributionMetrics String
  timestamp             DateTime @default(now()) @db.Timestamptz
  updatedAt             DateTime @updatedAt @db.Timestamptz

  @@map("commit_attributions")
}

model CasEntry {
  id               String   @id @default(uuid()) @db.Uuid
  hash             String   @unique
  encryptedContent String
  contentType      String   @default("text/plain")
  createdAt        DateTime @default(now()) @db.Timestamptz

  @@map("cas_entries")
}

model Config {
  id           String   @id @default(uuid()) @db.Uuid
  key          String   @unique @db.VarChar(255)
  value        String?  @db.Text
  description  String?  @db.Text
  category     String   @default("general") @db.VarChar(100)
  isSensitive  Boolean  @default(false) @map("is_sensitive")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([key])
  @@index([category])
  @@map("config")
}

model OauthDeviceCode {
  id              String   @id @default(uuid()) @db.Uuid
  deviceCode      String   @unique @map("device_code")
  userCode        String   @unique @map("user_code")
  clientId        String   @default("git-ai-cli") @map("client_id")
  verificationUri String   @map("verification_uri")
  status          String
  userId          String   @map("user_id")
  subjectJson     Json     @map("subject_json")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  expiresAt       DateTime @map("expires_at") @db.Timestamptz
  approvedAt      DateTime? @map("approved_at") @db.Timestamptz
  deniedAt        DateTime? @map("denied_at") @db.Timestamptz
  lastPolledAt    DateTime? @map("last_polled_at") @db.Timestamptz

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
  @@map("oauth_device_codes")
}

model MetricsEvent {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id")
  distinctId       String?  @map("distinct_id")
  schemaVersion    Int      @map("schema_version")
  eventTimestamp   DateTime @map("event_timestamp") @db.Timestamptz
  eventId          Int      @map("event_id")
  valuesJson       Json     @map("values_json")
  attrsJson        Json     @map("attrs_json")
  gitAiVersion     String?  @map("git_ai_version")
  repoUrl          String?  @map("repo_url")
  tool             String?
  model            String?
  promptId         String?  @map("prompt_id")
  externalPromptId String?  @map("external_prompt_id")
  receivedAt       DateTime @default(now()) @map("received_at") @db.Timestamptz

  @@index([userId])
  @@index([eventTimestamp])
  @@index([repoUrl])
  @@index([distinctId])
  @@map("metrics_events")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id")
  action     String
  resource   String
  paramsJson Json     @map("params_json")
  ip         String
  userAgent  String?  @map("user_agent")
  occurredAt DateTime @map("occurred_at") @db.Timestamptz
  success    Boolean
  details    String?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId])
  @@index([occurredAt])
  @@map("audit_logs")
}
